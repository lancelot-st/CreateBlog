---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts } from "../../lib/posts";
import { config, linkTo, readingTime, slugify } from "../../lib/site";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const minutes = readingTime(post.body);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="article-shell">
    <header class="article-header">
      <div class="post-meta">
        <span>{post.data.pubDate.toLocaleDateString(config.site.language)}</span>
        {config.appearance.showReadingTime && <span>{minutes} min read</span>}
      </div>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <div class="tag-row">
        {post.data.tags.map((tag) => (
          <a class="tag-chip" href={linkTo(`/tags/${slugify(tag)}`)}>{tag}</a>
        ))}
      </div>
    </header>

    <div class="article-layout">
      <div class="article-content">
        <Content />
      </div>
      <aside class="toc">
        <div class="toc-box">
          <p>On this page</p>
          <ul>
            {headings.map((heading) => (
              <li>
                <a href={`#${heading.slug}`}>{heading.text}</a>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>
