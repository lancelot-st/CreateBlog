---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import PostCard from "../components/PostCard.astro";
import { getPublishedPosts, getTagIndex } from "../lib/posts";

const posts = await getPublishedPosts();
const tags = await getTagIndex();
const featured = posts.find((post) => post.data.featured) ?? posts[0];
const rest = posts.filter((post) => post.id !== featured?.id);
---

<BaseLayout>
  <Hero postCount={posts.length} tagCount={tags.length} />

  {featured && (
    <section class="feature-grid">
      <div class="section-heading">
        <span>Featured</span>
        <h2>{featured.data.title}</h2>
      </div>
      <PostCard post={featured} priority />
    </section>
  )}

  <section class="content-grid" id="posts">
    <div class="section-heading">
      <span>Latest posts</span>
      <h2>Write locally. Publish by pushing to GitHub.</h2>
    </div>
    <div class="posts-grid">
      {rest.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
